# ===================================================================
# Danny Toolkit — Environment Variables
# ===================================================================
# Groq Velocity: Groq is de exclusieve primaire EN fallback LLM engine.
# Kopieer dit bestand naar .env en vul je keys in.
# ===================================================================

# --- VEREIST: Groq API (primaire + fallback engine) ---
GROQ_API_KEY=gsk_your_primary_key_here

# Multi-key isolatie (optioneel, voor rate-limit spreiding)
# GROQ_API_KEY_2=gsk_...
# GROQ_API_KEY_USER=gsk_...
# GROQ_API_KEY_VERIFY=gsk_...
# GROQ_API_KEY_RESEARCH=gsk_...
# GROQ_API_KEY_WALKER=gsk_...
# GROQ_API_KEY_FORGE=gsk_...
# GROQ_API_KEY_OVERNIGHT=gsk_...
# GROQ_API_KEY_KNOWLEDGE=gsk_...
# GROQ_API_KEY_RESERVE_1=gsk_...
# GROQ_API_KEY_RESERVE_2=gsk_...
# GROQ_API_KEY_RESERVE_3=gsk_...

# --- VEREIST: Voyage AI (embeddings) ---
VOYAGE_API_KEY=pa-your_voyage_key_here

# --- OPTIONEEL: Overige providers (niet in core loop) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ALLOW_ANTHROPIC=0
# NVIDIA_NIM_API_KEY=nvapi-...
# HF_TOKEN=hf_...
# OPENAI_API_KEY=sk-...
# ELEVENLABS_API_KEY=...

# --- Gebruiker ---
HOOFDGEBRUIKER_NAAM=Danny
HOOFDGEBRUIKER_EMAIL=danny.laurent1988@gmail.com

# --- Telegram Bot (optioneel) ---
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...
